# ── App ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lex:lex@postgres:5432/lexorchestrator
POSTGRES_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Providers ───────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLAMA_API_URL=

# ── Model Selection ─────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
LLAMA_MODEL=llama-3.1-8b-instruct
ANTHROPIC_MAX_TOKENS=4096

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_PROVIDER=hash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Security (required in staging/production) ────────────────
# CORS_ORIGINS=["https://app.example.com"]
# LEX_API_KEYS=key1,key2

# ── Retrieval Tuning ────────────────────────────────────────
# VECTOR_WEIGHT=0.70
# KEYWORD_WEIGHT=0.30
